{
  "name": "@canvasflow/feed",
  "description": "This is canvasflow utility for processing feeds",
  "version": "1.9.1",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "keywords": [
    "rss",
    "atom",
    "feed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/canvasflow/feed.git"
  },
  "bugs": {
    "url": "https://github.com/canvasflow/feed/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "npm run build && npm run --dry-run",
    "test": "vitest --ui",
    "test:debug": "vitest --test-timeout=0 --no-file-parallelism",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest --ui --tags-filter=unit",
    "test:integration": "vitest --ui --tags-filter=integration", 
    "test:todo": "vitest --ui --tags-filter=todo",
    "test:broken": "vitest --ui --tags-filter=broken",
    "lint": "eslint . --ext .ts",
    "lint:watch": "watch-eslint",
    "coverage": "vitest --coverage",
    "coverage:ui": "vitest --coverage --ui",
    "commit": "cz",
    "prepare": "husky",
    "format": "prettier --write ."
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog",
      "disableScopeLowerCase": false,
      "disableSubjectLowerCase": false,
      "maxHeaderWidth": 100,
      "maxLineWidth": 100
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@types/he": "^1.2.3",
    "@types/luxon": "^3.6.2",
    "@types/node": "^25.4.0",
    "@types/sanitize-html": "^2.16.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "cz-conventional-changelog": "^3.3.0",
    "cz-git": "^1.11.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5",
    "watch-eslint": "^1.1.0"
  },
  "engines": {
    "node": ">=20.19.2"
  },
  "volta": {
    "node": "24.14.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "fast-xml-builder": "^1.1.4",
    "fast-xml-parser": "^5.5.6",
    "he": "^1.2.0",
    "himalaya": "^1.1.1",
    "linkedom": "^0.18.12",
    "luxon": "^3.6.1",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "commitizen": {
      "lodash": "^4.17.22",
      "inquirer": "^9.3.7"
    },
    "tmp": "^0.2.4"
  }
}
