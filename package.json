{
  "name": "@canvasflow/feed",
  "description": "This is canvasflow utility for processing feeds",
  "version": "1.17.2",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "@canvasflow:registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "keywords": [
    "rss",
    "feed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Canvasflow/feed.git"
  },
  "bugs": {
    "url": "https://github.com/Canvasflow/feed/issues"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp pack",
    "test": "vp test",
    "test:debug": "vp test --test-timeout=0 --no-file-parallelism",
    "test:ui": "VP_VERSION=4.1.8 vp test watch --ui --open",
    "test:unit": "VP_VERSION=4.1.8 vp test --ui --tags-filter=unit",
    "test:integration": "VP_VERSION=4.1.8 vp test --ui --tags-filter=integration",
    "test:todo": "VP_VERSION=4.1.8 vp test --ui --tags-filter=todo",
    "test:broken": "VP_VERSION=4.1.8 vp test --ui --tags-filter=broken",
    "test:snapshot": "vp test src/**/*.snapshot.test.ts",
    "test:snapshot:update": "vp test --update src/**/*.snapshot.test.ts",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "coverage": "VP_VERSION=4.1.8 vp test --coverage",
    "coverage:ui": "VP_VERSION=4.1.8 vp test watch --coverage --ui --open",
    "commit": "cz",
    "format": "vp fmt .",
    "changelog": "node scripts/update-changelog.mjs",
    "prepare": "cp scripts/post-merge.sh .git/hooks/post-merge && chmod +x .git/hooks/post-merge"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog",
      "disableScopeLowerCase": false,
      "disableSubjectLowerCase": false,
      "maxHeaderWidth": 100,
      "maxLineWidth": 100
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/he": "^1.2.3",
    "@types/luxon": "^3.6.2",
    "@types/node": "^25.4.0",
    "@types/sanitize-html": "^2.16.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "cz-conventional-changelog": "^3.3.0",
    "typescript": "~6.0.3",
    "vite-plus": "^0.1.24"
  },
  "engines": {
    "node": ">=20.19.2"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.6",
    "he": "^1.2.0",
    "himalaya": "1.1.1",
    "linkedom": "^0.18.12",
    "luxon": "^3.6.1",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24",
    "commitizen": {
      "lodash": "^4.17.22",
      "inquirer": "^9.3.7"
    },
    "tmp": "^0.2.4"
  },
  "packageManager": "npm@11.16.0",
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
