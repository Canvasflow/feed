{
  "name": "@canvasflow/feed",
  "description": "This is canvasflow utility for processing feeds",
  "version": "1.11.7",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "keywords": [
    "rss",
    "atom",
    "feed"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/canvasflow/feed.git"
  },
  "bugs": {
    "url": "https://github.com/canvasflow/feed/issues"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp pack",
    "test": "vp test",
    "test:debug": "vp test --test-timeout=0 --no-file-parallelism",
    "test:run": "vp test run",
    "test:ui": "vp test watch --ui --open",
    "test:unit": "vp test --ui --tags-filter=unit",
    "test:integration": "vp test --ui --tags-filter=integration",
    "test:todo": "vp test --ui --tags-filter=todo",
    "test:broken": "vp test --ui --tags-filter=broken",
    "lint": "vp lint",
    "coverage": "vp test --coverage",
    "coverage:ui": "vp test --coverage --ui",
    "commit": "cz",
    "prepare": "vp config",
    "format": "vp fmt ."
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog",
      "disableScopeLowerCase": false,
      "disableSubjectLowerCase": false,
      "maxHeaderWidth": 100,
      "maxLineWidth": 100
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/he": "^1.2.3",
    "@types/luxon": "^3.6.2",
    "@types/node": "^25.4.0",
    "@types/sanitize-html": "^2.16.0",
    "@vitest/ui": "^4.1.8",
    "cz-conventional-changelog": "^3.3.0",
    "cz-git": "^1.11.1",
    "typescript": "~5.9.3",
    "vite-plus": "^0.1.24"
  },
  "engines": {
    "node": ">=20.19.2"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "fast-xml-builder": "^1.1.4",
    "fast-xml-parser": "^5.5.6",
    "he": "^1.2.0",
    "himalaya": "^1.1.1",
    "linkedom": "^0.18.12",
    "luxon": "^3.6.1",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24",
    "commitizen": {
      "lodash": "^4.17.22",
      "inquirer": "^9.3.7"
    },
    "tmp": "^0.2.4"
  },
  "packageManager": "npm@11.16.0"
}
